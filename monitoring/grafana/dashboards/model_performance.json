{
  "uid": "model-performance",
  "title": "Model Performance",
  "tags": ["model", "mlops"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5m",
  "time": { "from": "now-30d", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "F1 Score (modelo activo)",
      "type": "stat",
      "gridPos": { "w": 6, "h": 4, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "postgresql" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT f1_score AS \"F1 Score\"\nFROM model_deployments\nWHERE is_active IS TRUE\nLIMIT 1"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.85 },
              { "color": "green", "value": 0.9 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 2,
      "title": "AUC-ROC (modelo activo)",
      "type": "stat",
      "gridPos": { "w": 6, "h": 4, "x": 6, "y": 0 },
      "datasource": { "type": "postgres", "uid": "postgresql" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT auc_roc AS \"AUC-ROC\"\nFROM model_deployments\nWHERE is_active IS TRUE\nLIMIT 1"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.9 },
              { "color": "green", "value": 0.95 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 3,
      "title": "Precisión (modelo activo)",
      "type": "stat",
      "gridPos": { "w": 6, "h": 4, "x": 12, "y": 0 },
      "datasource": { "type": "postgres", "uid": "postgresql" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT precision AS \"Precisión\"\nFROM model_deployments\nWHERE is_active IS TRUE\nLIMIT 1"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "green", "value": 0.9 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 4,
      "title": "Recall (modelo activo)",
      "type": "stat",
      "gridPos": { "w": 6, "h": 4, "x": 18, "y": 0 },
      "datasource": { "type": "postgres", "uid": "postgresql" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT recall AS \"Recall\"\nFROM model_deployments\nWHERE is_active IS TRUE\nLIMIT 1"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "green", "value": 0.9 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 5,
      "title": "Latencia P50 / P95 / P99",
      "type": "timeseries",
      "gridPos": { "w": 24, "h": 9, "x": 0, "y": 4 },
      "datasource": { "type": "postgres", "uid": "postgresql" },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT\n  to_timestamp(floor(extract(epoch FROM \"timestamp\") / 300) * 300) AS time,\n  percentile_cont(0.50) WITHIN GROUP (ORDER BY latency_ms) AS \"P50 ms\",\n  percentile_cont(0.95) WITHIN GROUP (ORDER BY latency_ms) AS \"P95 ms\",\n  percentile_cont(0.99) WITHIN GROUP (ORDER BY latency_ms) AS \"P99 ms\"\nFROM predictions_history\nWHERE $__timeFilter(\"timestamp\")\nGROUP BY 1\nORDER BY 1"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 5,
            "gradientMode": "none",
            "drawStyle": "line",
            "spanNulls": false
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "P99 ms" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } },
              {
                "id": "custom.thresholdsStyle",
                "value": { "mode": "line" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "P95 ms" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }]
          },
          {
            "matcher": { "id": "byName", "options": "P50 ms" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"] },
        "thresholds": {
          "mode": "absolute",
          "steps": [
            { "color": "transparent", "value": null },
            { "color": "red", "value": 50 }
          ]
        },
        "thresholdsStyle": { "mode": "line+area" }
      }
    },
    {
      "id": 6,
      "title": "Distribución de scores del modelo",
      "type": "histogram",
      "gridPos": { "w": 12, "h": 9, "x": 0, "y": 13 },
      "datasource": { "type": "postgres", "uid": "postgresql" },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT\n  \"timestamp\" AS time,\n  prediction_score AS \"Score\"\nFROM predictions_history\nWHERE $__timeFilter(\"timestamp\")\nORDER BY \"timestamp\""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 80,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "options": {
        "bucketSize": "auto",
        "bucketOffset": 0,
        "fillOpacity": 80,
        "gradientMode": "none",
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 7,
      "title": "Champion vs. Challenger",
      "type": "table",
      "gridPos": { "w": 12, "h": 9, "x": 12, "y": 13 },
      "datasource": { "type": "postgres", "uid": "postgresql" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT\n  version AS \"Versión\",\n  CASE WHEN is_active THEN '✅ Champion' ELSE '🔵 Challenger' END AS \"Rol\",\n  ROUND(f1_score::numeric, 4) AS \"F1\",\n  ROUND(precision::numeric, 4) AS \"Precision\",\n  ROUND(recall::numeric, 4) AS \"Recall\",\n  ROUND(auc_roc::numeric, 4) AS \"AUC-ROC\",\n  created_at AS \"Fecha\"\nFROM model_deployments\nORDER BY created_at DESC\nLIMIT 5"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "displayMode": "auto",
            "align": "auto"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "F1" },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "red", "value": null },
                    { "color": "yellow", "value": 0.85 },
                    { "color": "green", "value": 0.9 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "AUC-ROC" },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "red", "value": null },
                    { "color": "yellow", "value": 0.9 },
                    { "color": "green", "value": 0.95 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Rol" },
            "properties": [
              {
                "id": "custom.width",
                "value": 140
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Fecha", "desc": true }],
        "footer": { "show": false, "reducer": ["sum"] }
      }
    }
  ]
}
